#include <stdio.h>

#define MAX 5

// Enum për status
enum Status {
    FAIL,
    PASS,
    EXCELLENT
};

// Struktura e studentit
struct Student {
    int id;
    char name[50];
    float score;
    enum Status status;
};

// Funksion për status
void setStatus(struct Student *s) {
    if (s->score < 50)
        s->status = FAIL;
    else if (s->score < 80)
        s->status = PASS;
    else
        s->status = EXCELLENT;
}

// Print status
void printStatus(enum Status st) {
    if (st == FAIL)
        printf("FAIL");
    else if (st == PASS)
        printf("PASS");
    else
        printf("EXCELLENT");
}

int main() {
    struct Student students[MAX];
    int count = 0;
    int choice;

    do {
        printf("\n--- MENU ---\n");
        printf("1. Add Student\n");
        printf("2. Show Students\n");
        printf("3. Exit\n");
        printf("Choice: ");
        scanf("%d", &choice);

        switch(choice) {

            case 1:
                if (count < MAX) {
                    printf("Enter ID: ");
                    scanf("%d", &students[count].id);

                    printf("Enter Name: ");
                    scanf("%s", students[count].name);

                    printf("Enter Score: ");
                    scanf("%f", &students[count].score);

                    setStatus(&students[count]); // pointer

                    count++;
                    printf("Student added!\n");
                } else {
                    printf("List is full!\n");
                }
                break;

            case 2:
                if (count == 0) {
                    printf("No students yet!\n");
                } else {
                    printf("\n--- STUDENTS ---\n");
                    for (int i = 0; i < count; i++) {
                        printf("ID: %d | Name: %s | Score: %.2f | Status: ",
                               students[i].id,
                               students[i].name,
                               students[i].score);
                        printStatus(students[i].status);
                        printf("\n");
                    }
                }
                break;

            case 3:
                printf("Exiting...\n");
                break;

            default:
                printf("Invalid choice!\n");
        }

    } while(choice != 3);

    return 0;
}
