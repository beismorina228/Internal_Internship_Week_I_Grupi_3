#include <stdio.h>
#include <string.h>

#define MAX_RECORDS 10
#define NAME_LENGTH 50

typedef enum
{
    NOT_STARTED = 1,
    IN_PROGRESS = 2,
    COMPLETED = 3
} Status;

typedef struct
{
    int id;
    char name[NAME_LENGTH];
    float progress;
    Status status;
} StudentRecord;

void clearInputBuffer()
{
    int c;
    while ((c = getchar()) != '\n' && c != EOF)
    {
    }
}

void printLine()
{
    printf("============================================================\n");
}

int readInt(const char *message, int *value)
{
    printf("%s", message);

    if (scanf("%d", value) != 1)
    {
        clearInputBuffer();
        return 0;
    }

    clearInputBuffer();
    return 1;
}

int readFloat(const char *message, float *value)
{
    printf("%s", message);

    if (scanf("%f", value) != 1)
    {
        clearInputBuffer();
        return 0;
    }

    clearInputBuffer();
    return 1;
}

int readText(const char *message, char text[], int size)
{
    printf("%s", message);
    fgets(text, size, stdin);
    text[strcspn(text, "\n")] = '\0';

    if (strlen(text) == 0)
    {
        return 0;
    }

    return 1;
}

const char *getStatusText(Status status)
{
    switch (status)
    {
        case NOT_STARTED:
            return "Not Started";
        case IN_PROGRESS:
            return "In Progress";
        case COMPLETED:
            return "Completed";
        default:
            return "Unknown";
    }
}

int getValidName(const char *message, char name[])
{
    if (!readText(message, name, NAME_LENGTH))
    {
        printf("Name cannot be empty.\n");
        return 0;
    }

    return 1;
}

int getValidProgress(const char *message, float *progress)
{
    if (!readFloat(message, progress))
    {
        printf("Invalid progress input.\n");
        return 0;
    }

    if (*progress < 0 || *progress > 100)
    {
        printf("Progress must be between 0 and 100.\n");
        return 0;
    }

    return 1;
}

int getValidStatus(Status *status)
{
    int choice;

    printLine();
    printf("STATUS MENU\n");
    printLine();
    printf("1. Not Started\n");
    printf("2. In Progress\n");
    printf("3. Completed\n");

    if (!readInt("Choose status: ", &choice))
    {
        printf("Invalid status input.\n");
        return 0;
    }

    switch (choice)
    {
        case 1:
            *status = NOT_STARTED;
            return 1;
        case 2:
            *status = IN_PROGRESS;
            return 1;
        case 3:
            *status = COMPLETED;
            return 1;
        default:
            printf("Invalid status choice.\n");
            return 0;
    }
}

int findRecordIndexById(StudentRecord records[], int count, int id)
{
    int i;

    for (i = 0; i < count; i++)
    {
        if (records[i].id == id)
        {
            return i;
        }
    }

    return -1;
}

void displayOneRecord(StudentRecord record, int number)
{
    printf("Record Number : %d\n", number);
    printf("ID            : %d\n", record.id);
    printf("Name          : %s\n", record.name);
    printf("Progress      : %.2f%%\n", record.progress);
    printf("Status        : %s\n", getStatusText(record.status));
}

void showRecommendation(StudentRecord record)
{
    printf("Interpretation: ");

    if (record.progress < 50 && record.status == NOT_STARTED)
    {
        printf("Warning - very low progress and the student has not started properly.\n");
    }
    else if (record.progress < 50 && record.status == IN_PROGRESS)
    {
        printf("Warning - progress is low. More support is recommended.\n");
    }
    else if (record.progress >= 50 && record.progress < 80 && record.status == IN_PROGRESS)
    {
        printf("Good - the student is progressing, but should continue working consistently.\n");
    }
    else if (record.progress >= 80 && record.progress < 100 && record.status == IN_PROGRESS)
    {
        printf("Very good - the student is close to completion.\n");
    }
    else if (record.progress == 100 && record.status == COMPLETED)
    {
        printf("Excellent - the student has fully completed the work.\n");
    }
    else if (record.progress == 100 && record.status != COMPLETED)
    {
        printf("Check data - progress is 100 percent but status is not Completed.\n");
    }
    else if (record.progress == 0 && record.status == COMPLETED)
    {
        printf("Check data - status is Completed but progress is 0 percent.\n");
    }
    else
    {
        printf("The record should be reviewed for consistency.\n");
    }
}

void addRecord(StudentRecord records[], int *count)
{
    int id;
    char name[NAME_LENGTH];
    float progress;
    Status status;

    if (*count >= MAX_RECORDS)
    {
        printf("\nMaximum limit reached. No more records can be added.\n");
        return;
    }

    printLine();
    printf("ADD NEW RECORD\n");
    printLine();

    if (!readInt("Enter student ID: ", &id))
    {
        printf("Invalid ID input.\n");
        return;
    }

    if (id <= 0)
    {
        printf("ID must be a positive number.\n");
        return;
    }

    if (findRecordIndexById(records, *count, id) != -1)
    {
        printf("A record with this ID already exists.\n");
        return;
    }

    if (!getValidName("Enter student name: ", name))
    {
        return;
    }

    if (!getValidProgress("Enter progress (0 - 100): ", &progress))
    {
        return;
    }

    if (!getValidStatus(&status))
    {
        return;
    }

    records[*count].id = id;
    strcpy(records[*count].name, name);
    records[*count].progress = progress;
    records[*count].status = status;

    (*count)++;

    printf("Record added successfully.\n");
}

void displayRecords(StudentRecord records[], int count)
{
    int i;

    if (count == 0)
    {
        printf("\nNo records stored yet.\n");
        return;
    }

    printLine();
    printf("STORED RECORDS\n");
    printLine();

    for (i = 0; i < count; i++)
    {
        displayOneRecord(records[i], i + 1);
        printLine();
    }
}

void showReport(StudentRecord records[], int count)
{
    int i;
    int completedCount = 0;
    float totalProgress = 0;
    float averageProgress;
    float highestProgress;
    float lowestProgress;

    if (count == 0)
    {
        printLine();
        printf("ANALYTIC REPORT\n");
        printLine();
        printf("No records available.\n");
        return;
    }

    highestProgress = records[0].progress;
    lowestProgress = records[0].progress;

    for (i = 0; i < count; i++)
    {
        totalProgress += records[i].progress;

        if (records[i].status == COMPLETED)
        {
            completedCount++;
        }

        if (records[i].progress > highestProgress)
        {
            highestProgress = records[i].progress;
        }

        if (records[i].progress < lowestProgress)
        {
            lowestProgress = records[i].progress;
        }
    }

    averageProgress = totalProgress / count;

    printLine();
    printf("ANALYTIC REPORT\n");
    printLine();
    printf("Total records     : %d\n", count);
    printf("Completed records : %d\n", completedCount);
    printf("Average progress  : %.2f%%\n", averageProgress);
    printf("Highest progress  : %.2f%%\n", highestProgress);
    printf("Lowest progress   : %.2f%%\n", lowestProgress);

    if (averageProgress >= 80)
    {
        printf("Class performance : Very good overall progress.\n");
    }
    else if (averageProgress >= 50)
    {
        printf("Class performance : Acceptable progress, but there is room for improvement.\n");
    }
    else
    {
        printf("Class performance : Low progress, more support is needed.\n");
    }

    if (completedCount == count)
    {
        printf("Completion status : All students are completed.\n");
    }
    else if (completedCount > 0)
    {
        printf("Completion status : Some students are completed.\n");
    }
    else
    {
        printf("Completion status : No completed students yet.\n");
    }
}

void searchById(StudentRecord records[], int count)
{
    int id;
    int index;

    if (count == 0)
    {
        printf("\nNo records available for searching.\n");
        return;
    }

    if (!readInt("Enter ID to search: ", &id))
    {
        printf("Invalid ID input.\n");
        return;
    }

    index = findRecordIndexById(records, count, id);

    printLine();
    printf("SEARCH RESULT\n");
    printLine();

    if (index == -1)
    {
        printf("No record found with this ID.\n");
        return;
    }

    displayOneRecord(records[index], index + 1);
    showRecommendation(records[index]);
}

void searchByName(StudentRecord records[], int count)
{
    int i;
    int found = 0;
    char name[NAME_LENGTH];

    if (count == 0)
    {
        printf("\nNo records available for searching.\n");
        return;
    }

    if (!getValidName("Enter full name to search: ", name))
    {
        return;
    }

    printLine();
    printf("SEARCH RESULT\n");
    printLine();

    for (i = 0; i < count; i++)
    {
        if (strcmp(records[i].name, name) == 0)
        {
            displayOneRecord(records[i], i + 1);
            showRecommendation(records[i]);
            printLine();
            found = 1;
        }
    }

    if (!found)
    {
        printf("No record found with this name.\n");
    }
}

void searchRecord(StudentRecord records[], int count)
{
    int choice;

    if (count == 0)
    {
        printf("\nNo records available for searching.\n");
        return;
    }

    printLine();
    printf("SEARCH MENU\n");
    printLine();
    printf("1. Search by ID\n");
    printf("2. Search by Name\n");

    if (!readInt("Choose search option: ", &choice))
    {
        printf("Invalid search menu input.\n");
        return;
    }

    switch (choice)
    {
        case 1:
            searchById(records, count);
            break;
        case 2:
            searchByName(records, count);
            break;
        default:
            printf("Invalid search option.\n");
            break;
    }
}

void editRecord(StudentRecord records[], int count)
{
    int id;
    int index;
    int choice;
    char newName[NAME_LENGTH];
    float newProgress;
    Status newStatus;

    if (count == 0)
    {
        printf("\nNo records available for editing.\n");
        return;
    }

    if (!readInt("Enter the ID of the record to edit: ", &id))
    {
        printf("Invalid ID input.\n");
        return;
    }

    index = findRecordIndexById(records, count, id);

    if (index == -1)
    {
        printf("No record found with this ID.\n");
        return;
    }

    printLine();
    printf("CURRENT RECORD\n");
    printLine();
    displayOneRecord(records[index], index + 1);

    printLine();
    printf("EDIT MENU\n");
    printLine();
    printf("1. Change name\n");
    printf("2. Change progress\n");
    printf("3. Change status\n");
    printf("4. Change name and progress\n");
    printf("5. Change progress and status\n");

    if (!readInt("Choose edit option: ", &choice))
    {
        printf("Invalid edit option input.\n");
        return;
    }

    switch (choice)
    {
        case 1:
            if (!getValidName("Enter new name: ", newName))
            {
                return;
            }
            strcpy(records[index].name, newName);
            break;
        case 2:
            if (!getValidProgress("Enter new progress (0 - 100): ", &newProgress))
            {
                return;
            }
            records[index].progress = newProgress;
            break;
        case 3:
            if (!getValidStatus(&newStatus))
            {
                return;
            }
            records[index].status = newStatus;
            break;
        case 4:
            if (!getValidName("Enter new name: ", newName))
            {
                return;
            }
            if (!getValidProgress("Enter new progress (0 - 100): ", &newProgress))
            {
                return;
            }
            strcpy(records[index].name, newName);
            records[index].progress = newProgress;
            break;
        case 5:
            if (!getValidProgress("Enter new progress (0 - 100): ", &newProgress))
            {
                return;
            }
            if (!getValidStatus(&newStatus))
            {
                return;
            }
            records[index].progress = newProgress;
            records[index].status = newStatus;
            break;
        default:
            printf("Invalid edit option.\n");
            return;
    }

    printf("Record updated successfully.\n");
}

void deleteRecordByPosition(StudentRecord records[], int *count, int index)
{
    int i;

    for (i = index; i < *count - 1; i++)
    {
        records[i] = records[i + 1];
    }

    (*count)--;
}

void deleteRecordById(StudentRecord records[], int *count)
{
    int id;
    int index;

    if (*count == 0)
    {
        printf("\nNo records available for deletion.\n");
        return;
    }

    if (!readInt("Enter the ID of the record to delete: ", &id))
    {
        printf("Invalid ID input.\n");
        return;
    }

    index = findRecordIndexById(records, *count, id);

    if (index == -1)
    {
        printf("No record found with this ID.\n");
        return;
    }

    deleteRecordByPosition(records, count, index);
    printf("Record deleted successfully.\n");
}

void deleteRecordByIndex(StudentRecord records[], int *count)
{
    int index;

    if (*count == 0)
    {
        printf("\nNo records available for deletion.\n");
        return;
    }

    if (!readInt("Enter exact record number to delete: ", &index))
    {
        printf("Invalid index input.\n");
        return;
    }

    if (index < 1 || index > *count)
    {
        printf("Invalid record number.\n");
        return;
    }

    deleteRecordByPosition(records, count, index - 1);
    printf("Record deleted successfully.\n");
}

void deleteRecord(StudentRecord records[], int *count)
{
    int choice;

    if (*count == 0)
    {
        printf("\nNo records available for deletion.\n");
        return;
    }

    printLine();
    printf("DELETE MENU\n");
    printLine();
    printf("1. Delete by ID\n");
    printf("2. Delete by record number\n");

    if (!readInt("Choose delete option: ", &choice))
    {
        printf("Invalid delete menu input.\n");
        return;
    }

    switch (choice)
    {
        case 1:
            deleteRecordById(records, count);
            break;
        case 2:
            deleteRecordByIndex(records, count);
            break;
        default:
            printf("Invalid delete option.\n");
            break;
    }
}

void showMenu()
{
    printLine();
    printf("STUDENT PROGRESS TRACKER\n");
    printLine();
    printf("1. Add record\n");
    printf("2. Display all records\n");
    printf("3. Show analytic report\n");
    printf("4. Search record\n");
    printf("5. Edit record\n");
    printf("6. Delete record\n");
    printf("7. Exit\n");
}

int main()
{
    StudentRecord records[MAX_RECORDS];
    int count = 0;
    int choice;

    do
    {
        showMenu();

        if (!readInt("Choose an option: ", &choice))
        {
            printf("Invalid menu input. Please enter a number.\n");
            continue;
        }

        switch (choice)
        {
            case 1:
                addRecord(records, &count);
                break;
            case 2:
                displayRecords(records, count);
                break;
            case 3:
                showReport(records, count);
                break;
            case 4:
                searchRecord(records, count);
                break;
            case 5:
                editRecord(records, count);
                break;
            case 6:
                deleteRecord(records, &count);
                break;
            case 7:
                printf("Program closed.\n");
                break;
            default:
                printf("Invalid menu choice. Try again.\n");
                break;
        }
    }
    while (choice != 7);

    return 0;
}
