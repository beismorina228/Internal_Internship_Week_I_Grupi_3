#include <stdio.h>

int main() {
    int age, option;
    char initial;
    double points;

    // Input
    printf("Enter your age: ");
    scanf("%d", &age);

    printf("Enter your initial: ");
    scanf(" %c", &initial);

    printf("Enter your points: ");
    scanf("%lf", &points);

    printf("Choose workshop (1-3): ");
    scanf("%d", &option);

    // Kontroll moshe
    if(age < 15 || age > 30) {
        printf("Age not eligible for participation.\n");
    }

    // Klasifikimi me if/else
    printf("\n--- Evaluation ---\n");

    if(points < 50) {
        printf("Needs more practice\n");
    }
    else if(points < 80) {
        printf("Ready to continue\n");
    }
    else {
        printf("Ready for challenge\n");
    }

    // Switch për workshop
    printf("\n--- Workshop ---\n");

    switch(option) {
        case 1:
            printf("Programming Basics\n");
            break;
        case 2:
            printf("Web Development\n");
            break;
        case 3:
            printf("Data Analysis\n");
            break;
        default:
            printf("Invalid workshop option\n");
    }

    // Përmbledhje finale
    printf("\n--- Summary ---\n");
    printf("Age: %d\n", age);
    printf("Initial: %c\n", initial);
    printf("Points: %.2lf\n", points);
    printf("Workshop option: %d\n", option);

    return 0;
}
