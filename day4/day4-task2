#include <stdio.h>
#include <string.h>

#define MAX 5

// Enum për statusin
typedef enum {
    FILLESTAR = 1,
    MESATAR = 2,
    AVANCUAR = 3
} Statusi;

// Struktura për regjistrim
struct Progresi {
    char emri[50];
    int mosha;
    double pike;
    Statusi statusi;
};

// Funksion për ta kthyer enum në tekst
const char* statusNeText(Statusi s) {
    switch (s) {
        case FILLESTAR:
            return "Fillestar";
        case MESATAR:
            return "Mesatar";
        case AVANCUAR:
            return "Avancuar";
        default:
            return "Status i panjohur";
    }
}

int main() {
    struct Progresi regjistrimet[MAX];
    int numriAktual = 0;
    int zgjedhja;

    do {
        printf("\n===== MENUJA =====\n");
        printf("1. Shto regjistrim te ri\n");
        printf("2. Shfaq te gjitha regjistrimet\n");
        printf("3. Dil\n");
        printf("Zgjedh zgjedhjen: ");
        scanf("%d", &zgjedhja);

        switch (zgjedhja) {
            case 1:
                if (numriAktual >= MAX) {
                    printf("Nuk mund te shtoni me regjistrime. Eshte arritur maksimumi.\n");
                    break;
                }

                printf("Shkruaj emrin: ");
                scanf(" %[^\n]", regjistrimet[numriAktual].emri);

                printf("Shkruaj moshen: ");
                scanf("%d", &regjistrimet[numriAktual].mosha);

                printf("Shkruaj piket: ");
                scanf("%lf", &regjistrimet[numriAktual].pike);

                int statusInput;
                printf("Zgjidh statusin:\n");
                printf("1. Fillestar\n");
                printf("2. Mesatar\n");
                printf("3. Avancuar\n");
                printf("Zgjedhja: ");
                scanf("%d", &statusInput);

                switch (statusInput) {
                    case 1:
                        regjistrimet[numriAktual].statusi = FILLESTAR;
                        break;
                    case 2:
                        regjistrimet[numriAktual].statusi = MESATAR;
                        break;
                    case 3:
                        regjistrimet[numriAktual].statusi = AVANCUAR;
                        break;
                    default:
                        printf("Status i pavlefshem! Regjistrimi nuk u ruajt.\n");
                        break;
                }

                if (statusInput >= 1 && statusInput <= 3) {
                    numriAktual++;
                    printf("Regjistrimi u ruajt me sukses.\n");
                    printf("Numri aktual: %d / %d\n", numriAktual, MAX);
                }

                break;

            case 2:
                if (numriAktual == 0) {
                    printf("Nuk ka regjistrime te ruajtura.\n");
                } else {
                    printf("\n===== TE GJITHA REGJISTRIMET =====\n");
                    for (int i = 0; i < numriAktual; i++) {
                        printf("\nRegjistrimi #%d\n", i + 1);
                        printf("Emri    : %s\n", regjistrimet[i].emri);
                        printf("Mosha   : %d\n", regjistrimet[i].mosha);
                        printf("Piket   : %.2lf\n", regjistrimet[i].pike);
                        printf("Statusi : %s\n", statusNeText(regjistrimet[i].statusi));
                        printf("-------------------------\n");
                    }
                }
                break;

            case 3:
                printf("Programi u mbyll.\n");
                break;

            default:
                printf("Zgjedhje e pavlefshme ne menu! Provo perseri.\n");
        }

    } while (zgjedhja != 3);

    return 0;
}
