#include <stdio.h>
#include <string.h>

#define MAX 5

// Struktura për regjistrim
struct Progresi {
    char emri[50];
    int mosha;
    double pike;
    char niveli[50];
};

int main() {
    struct Progresi regjistrimet[MAX];
    int numriAktual = 0;
    int zgjedhja;

    do {
        printf("\n===== MENYJA =====\n");
        printf("1. Shto regjistrim te ri\n");
        printf("2. Shfaq te gjitha regjistrimet\n");
        printf("3. Dil\n");
        printf("Zgjedhja juaj: ");
        scanf("%d", &zgjedhja);

        switch (zgjedhja) {

            case 1:
                if (numriAktual >= MAX) {
                    printf("Kufiri maksimal eshte arritur!\n");
                } else {
                    printf("Shkruaj emrin: ");
                    scanf(" %[^\n]", regjistrimet[numriAktual].emri);

                    printf("Shkruaj moshen: ");
                    scanf("%d", &regjistrimet[numriAktual].mosha);

                    printf("Shkruaj piket: ");
                    scanf("%lf", &regjistrimet[numriAktual].pike);

                    // Vendos nivelin sipas pikëve
                    if (regjistrimet[numriAktual].pike < 50) {
                        strcpy(regjistrimet[numriAktual].niveli, "Nevojitet me shume ushtrim");
                    } else if (regjistrimet[numriAktual].pike <= 80) {
                        strcpy(regjistrimet[numriAktual].niveli, "Gati per vazhdim");
                    } else {
                        strcpy(regjistrimet[numriAktual].niveli, "Gati per sfide");
                    }

                    numriAktual++;

                    printf("Regjistrimi u shtua me sukses!\n");
                    printf("Totali: %d/%d\n", numriAktual, MAX);
                }
                break;

            case 2:
                if (numriAktual == 0) {
                    printf("Nuk ka regjistrime!\n");
                } else {
                    printf("\n===== LISTA =====\n");
                    for (int i = 0; i < numriAktual; i++) {
                        printf("\nRegjistrimi #%d\n", i + 1);
                        printf("Emri   : %s\n", regjistrimet[i].emri);
                        printf("Mosha  : %d\n", regjistrimet[i].mosha);
                        printf("Piket  : %.2lf\n", regjistrimet[i].pike);
                        printf("Niveli : %s\n", regjistrimet[i].niveli);
                        printf("----------------------\n");
                    }
                }
                break;

            case 3:
                printf("Programi u mbyll.\n");
                break;

            default:
                printf("Zgjedhje e pavlefshme!\n");
        }

    } while (zgjedhja != 3);

    return 0;
}
