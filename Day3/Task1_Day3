#include <stdio.h>

int main() {
    int n, choice;

    // Input size
    printf("Enter size (1-12): ");
    scanf("%d", &n);

    // Validate input
    if (n < 1 || n > 12) {
        printf("Invalid input!\n");
        return 0;
    }

    // Choose pattern
    printf("Choose pattern:\n");
    printf("1. Stars (*)\n");
    printf("2. Numbers\n");
    printf("Enter choice: ");
    scanf("%d", &choice);

    printf("\n--- Pattern ---\n");

    // Pattern logic
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= i; j++) {

            if (choice == 1) {
                printf("* ");
            } 
            else if (choice == 2) {
                printf("%d ", j);
            } 
            else {
                printf("Invalid choice!\n");
                return 0;
            }

        }
        printf("\n");
    }

    return 0;
}
