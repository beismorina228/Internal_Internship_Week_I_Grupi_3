    int max = students[0].progress;
    int min = students[0].progress;

    for (int i = 0; i < count; i++) {
        sum += students[i].progress;

        if (students[i].status == DONE) done++;

        if (students[i].progress > max) max = students[i].progress;
        if (students[i].progress < min) min = students[i].progress;
    }

    float avg = (float)sum / count;

    printf("\n=== REPORT ===\n");
    printf("Total: %d\n", count);
    printf("Completed: %d\n", done);
    printf("Average: %.2f%%\n", avg);
    printf("Max: %d%%\n", max);
    printf("Min: %d%%\n", min);

