#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_STUDENTS 5
#define NAME_LENGTH 50
#define INPUT_SIZE 128

typedef enum {
    TODO = 1,
    IN_PROGRESS = 2,
    DONE = 3
} StudentStatus;

typedef struct {
    int id;
    char name[NAME_LENGTH];
    int progress;
    StudentStatus status;
} Student;

int readInt(const char *prompt);
void readString(const char *prompt, char *buffer, int size);
StudentStatus readStatus(void);
const char *statusToString(StudentStatus status);
int findStudentIndexById(const Student students[], int count, int id);
void updateProgress(int *progress, StudentStatus *status, int newProgress);
void addStudent(Student students[], int *count);
void displayStudents(const Student students[], int count);
void updateStudentProgress(Student students[], int count);
void clearInputBuffer(void);

int main(void) {
    Student students[MAX_STUDENTS];
    int studentCount = 0;
    int choice;

    do {
        printf("\n=== Student Progress Tracker ===\n");
        printf("1. Add student\n");
        printf("2. Show all students\n");
        printf("3. Update student progress\n");
        printf("4. Exit\n");

        choice = readInt("Choose an option: ");

        switch (choice) {
            case 1:
                addStudent(students, &studentCount);
                break;
            case 2:
                displayStudents(students, studentCount);
                break;
            case 3:
                updateStudentProgress(students, studentCount);
                break;
            case 4:
                printf("Exiting program. Goodbye!\n");
                break;
            default:
                printf("Invalid option. Please choose between 1 and 4.\n");
        }
    } while (choice != 4);

    return 0;
}

int readInt(const char *prompt) {
    char input[INPUT_SIZE];
    char *endPtr;
    long value;

    while (1) {
        printf("%s", prompt);

        if (fgets(input, sizeof(input), stdin) == NULL) {
            printf("Input error. Please try again.\n");
            clearerr(stdin);
            continue;
        }

        value = strtol(input, &endPtr, 10);

        if (endPtr == input) {
            printf("Invalid number. Please enter a valid integer.\n");
            continue;
        }

        while (*endPtr == ' ' || *endPtr == '\t') {
            endPtr++;
        }

        if (*endPtr != '\n' && *endPtr != '\0') {
            printf("Unexpected characters found. Please enter only a number.\n");
            continue;
        }

        return (int)value;
    }
}

void readString(const char *prompt, char *buffer, int size) {
    while (1) {
        printf("%s", prompt);

        if (fgets(buffer, size, stdin) == NULL) {
            printf("Input error. Please try again.\n");
            clearerr(stdin);
            continue;
        }

        if (strchr(buffer, '\n') == NULL) {
            clearInputBuffer();
        } else {
            buffer[strcspn(buffer, "\n")] = '\0';
        }

        if (strlen(buffer) == 0) {
            printf("Name cannot be empty.\n");
        } else {
            return;
        }
    }
}

StudentStatus readStatus(void) {
    int choice;

    while (1) {
        printf("Select status:\n");
        printf("1. TODO\n");
        printf("2. IN_PROGRESS\n");
        printf("3. DONE\n");

        choice = readInt("Enter status number: ");

        if (choice >= TODO && choice <= DONE) {
            return (StudentStatus)choice;
        }

        printf("Invalid status. Please choose 1, 2, or 3.\n");
    }
}

const char *statusToString(StudentStatus status) {
    switch (status) {
        case TODO:
            return "TODO";
        case IN_PROGRESS:
            return "IN_PROGRESS";
        case DONE:
            return "DONE";
        default:
            return "UNKNOWN";
    }
}

int findStudentIndexById(const Student students[], int count, int id) {
    int i;

    for (i = 0; i < count; i++) {
        if (students[i].id == id) {
            return i;
        }
    }

    return -1;
}

void updateProgress(int *progress, StudentStatus *status, int newProgress) {
    *progress = newProgress;

    if (newProgress == 0) {
        *status = TODO;
    } else if (newProgress < 100) {
        *status = IN_PROGRESS;
    } else {
        *status = DONE;
    }
}

void addStudent(Student students[], int *count) {
    Student newStudent;

    if (*count >= MAX_STUDENTS) {
        printf("Cannot add more students. Maximum capacity reached.\n");
        return;
    }

    newStudent.id = readInt("Enter student ID: ");
    if (newStudent.id <= 0) {
        printf("Invalid ID. ID must be greater than 0.\n");
        return;
    }

    if (findStudentIndexById(students, *count, newStudent.id) != -1) {
        printf("A student with this ID already exists.\n");
        return;
    }

    readString("Enter student name: ", newStudent.name, NAME_LENGTH);

    newStudent.progress = readInt("Enter progress percentage (0-100): ");
    if (newStudent.progress < 0 || newStudent.progress > 100) {
        printf("Invalid progress. Progress must be between 0 and 100.\n");
        return;
    }

    newStudent.status = readStatus();

    students[*count] = newStudent;
    (*count)++;

    printf("Student added successfully.\n");
}

void displayStudents(const Student students[], int count) {
    int i;

    if (count == 0) {
        printf("No students found.\n");
        return;
    }

    printf("\n--- Student List ---\n");
    for (i = 0; i < count; i++) {
        printf("Student %d\n", i + 1);
        printf("ID: %d\n", students[i].id);
        printf("Name: %s\n", students[i].name);
        printf("Progress: %d%%\n", students[i].progress);
        printf("Status: %s\n", statusToString(students[i].status));
        printf("--------------------\n");
    }
}

void updateStudentProgress(Student students[], int count) {
    int id;
    int index;
    int newProgress;

    if (count == 0) {
        printf("No students available to update.\n");
        return;
    }

    id = readInt("Enter the student ID to update: ");
    if (id <= 0) {
        printf("Invalid ID. ID must be greater than 0.\n");
        return;
    }

    index = findStudentIndexById(students, count, id);
    if (index == -1) {
        printf("Student with ID %d was not found.\n", id);
        return;
    }

    newProgress = readInt("Enter new progress percentage (0-100): ");
    if (newProgress < 0 || newProgress > 100) {
        printf("Invalid progress. Progress must be between 0 and 100.\n");
        return;
    }

    updateProgress(&students[index].progress, &students[index].status, newProgress);
    printf("Progress updated successfully for %s.\n", students[index].name);
}

void clearInputBuffer(void) {
    int ch;

    while ((ch = getchar()) != '\n' && ch != EOF) {
    }
}
