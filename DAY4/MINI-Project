        printf("1. Add student\n");
        printf("2. Show students\n");
        printf("3. Update progress\n");
        printf("4. Report\n");
        printf("5. Search student\n");
        printf("6. Exit\n");

        choice = readInt("Choose: ");

        switch (choice) {
            case 1: addStudent(students, &studentCount); break;
            case 2: displayStudents(students, studentCount); break;
            case 3: updateStudentProgress(students, studentCount); break;
            case 4: generateReport(students, studentCount); break;
            case 5: searchStudent(students, studentCount); break;
            case 6: printf("Goodbye!\n"); break;
            default: printf("Invalid option!\n");
        }

    } while (choice != 6);

    return 0;
}

/* INPUT SAFE FUNCTIONS */
int readInt(const char *prompt) {
    char input[INPUT_SIZE];
    char *end;
    long val;

    while (1) {
        printf("%s", prompt);

        if (!fgets(input, sizeof(input), stdin)) {
            printf("Error!\n");
            continue;
        }

        val = strtol(input, &end, 10);

        if (end == input) {
            printf("Invalid number!\n");
            continue;
        }

        return (int)val;
    }
}

void readString(const char *prompt, char *buffer, int size) {
    while (1) {
        printf("%s", prompt);

        if (!fgets(buffer, size, stdin)) {
            printf("Error!\n");
            continue;
        }

        buffer[strcspn(buffer, "\n")] = '\0';

        if (strlen(buffer) == 0) {
            printf("Empty not allowed!\n");
        } else {
            return;
        }
    }
}

/* STATUS */
StudentStatus readStatus(void) {
    int c;

    while (1) {
        printf("1-TODO\n2-IN_PROGRESS\n3-DONE\n");
        c = readInt("Status: ");

        if (c >= 1 && c <= 3)
            return (StudentStatus)c;

        printf("Invalid status!\n");
    }
}

const char *statusToString(StudentStatus s) {
    switch (s) {
        case TODO: return "TODO";
        case IN_PROGRESS: return "IN_PROGRESS";
        case DONE: return "DONE";
        default: return "UNKNOWN";
    }
}

/* FIND */
int findStudentIndexById(const Student students[], int count, int id) {
    for (int i = 0; i < count; i++) {
        if (students[i].id == id)
            return i;
    }
    return -1;
}

/* POINTER FUNCTION */
void updateProgress(int *progress, StudentStatus *status, int newProgress) {
    *progress = newProgress;

    if (newProgress == 0)
        *status = TODO;
    else if (newProgress < 100)
        *status = IN_PROGRESS;
    else
        *status = DONE;
}

/* ADD */
void addStudent(Student students[], int *count) {
    if (*count >= MAX_STUDENTS) {
        printf("Max reached!\n");
        return;
    }

    Student s;

    s.id = readInt("ID: ");
    if (s.id <= 0) {
        printf("Invalid ID!\n");
        return;
    }

    if (findStudentIndexById(students, *count, s.id) != -1) {
        printf("ID exists!\n");
        return;
    }

    readString("Name: ", s.name, NAME_LENGTH);

    s.progress = readInt("Progress (0-100): ");
    if (s.progress < 0 || s.progress > 100) {
        printf("Invalid progress!\n");
        return;
    }

    s.status = readStatus();

    students[*count] = s;
    (*count)++;

    printf("Added!\n");
}

/* DISPLAY */
void displayStudents(const Student students[], int count) {
    if (count == 0) {
        printf("No data!\n");
        return;
    }

    for (int i = 0; i < count; i++) {
        printf("\nID: %d | Name: %s | Progress: %d%% | Status: %s\n",
               students[i].id,
               students[i].name,
               students[i].progress,
               statusToString(students[i].status));
    }
}

/* UPDATE */
void updateStudentProgress(Student students[], int count) {
    if (count == 0) {
        printf("Empty!\n");
        return;
    }

    int id = readInt("ID: ");
    int index = findStudentIndexById(students, count, id);

    if (index == -1) {
        printf("Not found!\n");
        return;
    }

    int p = readInt("New progress: ");
    if (p < 0 || p > 100) {
        printf("Invalid!\n");
        return;
    }

    updateProgress(&students[index].progress,
                   &students[index].status,
                   p);

    printf("Updated!\n");
}

/* REPORT */
void generateReport(const Student students[], int count) {
    if (count == 0) {
        printf("No report data!\n");
        return;
    }

    int done = 0, sum = 0;
    int max = students[0].progress;
    int min = students[0].progress;

    for (int i = 0; i < count; i++) {
        sum += students[i].progress;

        if (students[i].status == DONE)
            done++;

        if (students[i].progress > max)
            max = students[i].progress;

        if (students[i].progress < min)
            min = students[i].progress;
    }

    float avg = (float)sum / count;

    printf("\n=== REPORT ===\n");
    printf("Total: %d\n", count);
    printf("Done: %d\n", done);
    printf("Average: %.2f%%\n", avg);
    printf("Max: %d%%\n", max);
    printf("Min: %d%%\n", min);

    if (avg >= 80)
        printf("Performance: HIGH\n");
    else if (avg >= 50)
        printf("Performance: MEDIUM\n");
    else
        printf("Performance: LOW\n");
}

/* SEARCH + EVALUATION */
void searchStudent(const Student students[], int count) {
    if (count == 0) {
        printf("No students!\n");
        return;
    }

    int opt = readInt("1-ID  2-Name: ");
    int found = 0;

    if (opt == 1) {
        int id = readInt("Enter ID: ");

        for (int i = 0; i < count; i++) {
            if (students[i].id == id) {
                printf("\nFOUND:\n%s | %d%% | %s\n",
                       students[i].name,
                       students[i].progress,
                       statusToString(students[i].status));

                evaluateStudent(&students[i]);
                found = 1;
                break;
            }
        }
    }
    else if (opt == 2) {
        char name[NAME_LENGTH];
        readString("Enter name: ", name, NAME_LENGTH);

        for (int i = 0; i < count; i++) {
            if (strcmp(students[i].name, name) == 0) {
                printf("\nFOUND:\nID:%d | %d%% | %s\n",
                       students[i].id,
                       students[i].progress,
                       statusToString(students[i].status));

                evaluateStudent(&students[i]);
                found = 1;
            }
        }
    }
    else {
        printf("Invalid option!\n");
        return;
    }

    if (!found)
        printf("No match found!\n");
}

/* SMART LOGIC */
void evaluateStudent(const Student *s) {
    printf("\n--- ANALYSIS ---\n");

    if (s->progress == 0 && s->status == TODO)
        printf("Not started.\n");

    else if (s->progress < 50 && s->status == IN_PROGRESS)
        printf("Warning: Low progress.\n");

    else if (s->progress >= 50 && s->progress < 100)
        printf("Good progress.\n");

    else if (s->progress == 100 && s->status == DONE)
        printf("Excellent completion!\n");

    else if (s->progress == 100 && s->status != DONE)
        printf("Inconsistent data!\n");

    else
        printf("Check status.\n");
}

/* CLEAN INPUT */
void clearInputBuffer(void) {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}
