    if (avg >= 80)
        printf("High performance.\n");
    else if (avg >= 50)
        printf("Medium performance.\n");
    else
        printf("Low performance.\n");

    if (done == count)
        printf("All completed.\n");
    else if (done == 0)
        printf("None completed.\n");
    else
        printf("Work in progress.\n");
}

